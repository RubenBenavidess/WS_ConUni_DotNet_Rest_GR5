@startuml
title "DS_09_ERROR_VALIDACION_400"
autonumber

actor "APLICACION" as Aplicacion
participant "CONVERSION_VISTA" as ConversionVista
participant "CONVERSION_CONTROLADOR" as ConversionControlador
participant "CLIENTE_REST_CONVERSOR" as ClienteRest
participant "BEARER_TOKEN_AUTHENTICATION_HANDLER" as BearerHandler
participant "CONVERSIONES_CONTROLLER" as ConversionesController
participant "SERVICIO_CONVERSION" as ServicioConversion

Aplicacion -> ConversionVista: Ingresa unidad no soportada
ConversionVista -> ConversionControlador: solicitarConversionMasa(valor, unidadOrigenInvalida, unidadDestino)
ConversionControlador -> ClienteRest: convertirMasa(tokenSesion, valor, unidadOrigenInvalida, unidadDestino)

ClienteRest -> BearerHandler: POST /api/conversiones/masa\nAuthorization: Bearer token
BearerHandler --> ConversionesController: solicitud autorizada

ConversionesController -> ServicioConversion: ConvertirMasa(valor, unidadOrigen, unidadDestino)
ServicioConversion -> ServicioConversion: ParseUnidad(unidadOrigen)
ServicioConversion --> ConversionesController: ArgumentException("Unidad no soportada")
ConversionesController --> ClienteRest: 400 "Unidad no soportada: ..."

ClienteRest --> ConversionControlador: error de validacion
ConversionControlador --> ConversionVista: mostrar mensaje de validacion
ConversionVista --> Aplicacion: solicitar correccion de datos

@enduml
