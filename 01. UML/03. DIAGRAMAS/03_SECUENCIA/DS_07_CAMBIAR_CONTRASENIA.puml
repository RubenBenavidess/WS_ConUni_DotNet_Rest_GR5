@startuml
title "DS_07_CAMBIAR_CONTRASENIA"
autonumber

actor "APLICACION" as Aplicacion
participant "CONVERSION_VISTA" as ConversionVista
participant "LOGIN_CONTROLADOR" as LoginControlador
participant "CLIENTE_REST_CONVERSOR" as ClienteRest
participant "BEARER_TOKEN_AUTHENTICATION_HANDLER" as BearerHandler
participant "SEGURIDAD_CONTROLLER" as SeguridadController
participant "AUTH_SERVICE" as AuthService

Aplicacion -> ConversionVista: Solicita cambiar contrasenia
ConversionVista -> LoginControlador: cambiarContrasenia(actual, nueva)
LoginControlador -> LoginControlador: valida campos no vacios

LoginControlador -> ClienteRest: cambiarContrasenia(tokenSesion, actual, nueva)
ClienteRest -> BearerHandler: POST /api/seguridad/cambiar-contrasena\nAuthorization: Bearer token\n{contrasenaActual, nuevaContrasena}
BearerHandler -> BearerHandler: valida esquema Bearer y token activo
BearerHandler --> SeguridadController: solicitud autorizada

SeguridadController -> AuthService: CambiarContrasena(actual, nueva)
alt cambio exitoso
    AuthService -> AuthService: actualiza contrasenia y limpia tokens activos
    SeguridadController --> ClienteRest: 200 "Contrasenia actualizada"
    ClienteRest --> LoginControlador: confirmacion
    LoginControlador --> ConversionVista: mostrar exito
else error de validacion
    AuthService --> SeguridadController: false
    SeguridadController --> ClienteRest: 400 "No se pudo cambiar la contrasenia"
    ClienteRest --> LoginControlador: error
    LoginControlador --> ConversionVista: mostrar mensaje
end

@enduml
